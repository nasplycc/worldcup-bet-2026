# =============================================
# AI 智球 · 世界杯竞彩预测系统 — 环境变量
# =============================================
# 此文件通过 volume 挂载到 Docker 容器
# 敏感信息请勿提交到 Git

# =============================================
# 1. AI 分析配置（OpenAI 兼容接口）
# =============================================
# 填入你的 OpenAI API Key（或其他兼容 API 的 Key）
OPENAI_API_KEY=sk-sp-bd784467daba4d9b96d106a23f2431d8
# API 基础地址（默认 OpenAI，可改为其他兼容服务）
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# 使用的模型名称
OPENAI_MODEL=qwen3.6-plus

# =============================================
# 2. 足球数据 API
# =============================================
# football-data.org — 英超赛程/积分/射手数据
FOOTBALL_DATA_API_KEY=c2b749da3c1744149d22c08dc5baf68e

# API-Football（v3.football.api-sports.io）— 赔率数据
API_FOOTBALL_KEY=6e7110186e0aefd3dcf5966ff170194f
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# The Odds API — 实时赔率数据
THE_ODDS_API_KEY=fb2b011264138dbf05a73a4278b04d23
THE_ODDS_API_REGIONS=eu

# 联赛数据源配置
# 英超
THE_ODDS_API_EPL_SPORT=soccer_epl
API_FOOTBALL_EPL_LEAGUE=39
API_FOOTBALL_EPL_SEASON=2025
# 世界杯
THE_ODDS_API_WORLDCUP_SPORT=soccer_fifa_world_cup
API_FOOTBALL_WORLDCUP_LEAGUE=1
API_FOOTBALL_WORLDCUP_SEASON=2026

# =============================================
# 3. Telegram 通知（可选）
# =============================================
# 启用后，比赛推荐/赔率变动会推送到 Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================
# 4. 运行模式
# =============================================
# signal / telegram / web（当前使用 signal 模式）
RUN_MODE=signal

# =============================================
# 5. 数据库配置（PostgreSQL）
# =============================================
# DATABASE_URL 格式: postgresql+psycopg2://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg2://worldcup:mine3SURFACE138@db:5432/worldcup_ai
POSTGRES_DB=worldcup_ai
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=mine3SURFACE138

# =============================================
# 6. 认证 & 安全
# =============================================
# JWT Token 加密密钥（建议修改为强随机字符串）
JWT_SECRET=mine3SURFACE138
# JWT Token 有效期（小时），默认 7 天
JWT_TTL_HOURS=168
# 管理员 Token（用于 admin API 鉴权，留空则使用 JWT 鉴权）
ADMIN_TOKEN=wc2026-admin-secret-key

# =============================================
# 7. AI 分析管道（Codex 新增）
# =============================================
# 是否启用 AI 自动分析（需要 OPENAI_API_KEY）
AI_ANALYSIS_ENABLED=ture
# AI 分析提示词版本
AI_ANALYSIS_PROMPT_VERSION=v1
# 前瞻分析时间范围（小时），默认 7 天
AI_ANALYSIS_LOOKAHEAD_HOURS=168
# 每次同步最多创建的分析任务数
AI_ANALYSIS_MAX_JOBS_PER_SYNC=3
# 每日 AI 分析任务上限
AI_ANALYSIS_DAILY_JOB_LIMIT=20
# 失败重试次数
AI_ANALYSIS_MAX_RETRIES=2

# =============================================
# 8. 数据同步设置
# =============================================
# 是否启用自动同步（默认启用）
AUTO_SYNC_ENABLED=true
# 自动同步间隔（分钟），默认 60 分钟
AUTO_SYNC_INTERVAL_MINUTES=60
# 容器启动后延迟同步的秒数（等待 DB 就绪）
SYNC_STARTUP_DELAY_SECONDS=20

# Match Data Sync Limit
MATCH_DATA_SYNC_LIMIT=12

# Added from .env.example by sync_env.py

# Free/public fallback source for basic fixture/event enrichment.
# Public demo key 123 may be rate-limited; use your own TheSportsDB key if available.
THE_SPORTSDB_KEY=123

THE_SPORTSDB_BASE=https://www.thesportsdb.com/api/v1/json

THE_SPORTSDB_SYNC_LIMIT=8

THE_SPORTSDB_EPL_LEAGUE_ID=4328

THE_SPORTSDB_EPL_SEASON=2025-2026

THE_SPORTSDB_WORLDCUP_LEAGUE_ID=

THE_SPORTSDB_WORLDCUP_SEASON=2026


# China Sports Lottery public football feed fallback.
# This uses only public web gateway data, low frequency, and can be disabled if the source blocks NAS requests.
SPORTTERY_ENABLED=true

SPORTTERY_BASE=https://webapi.sporttery.cn/gateway

SPORTTERY_SYNC_LIMIT=20

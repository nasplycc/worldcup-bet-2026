# OpenAI-compatible model API used by the built-in Docker AI analysis pipeline.
# Leave OPENAI_API_KEY empty and AI_ANALYSIS_ENABLED=false if analysis is handled outside the container.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL connection used by Docker Compose. Change password values before production use.
DATABASE_URL=postgresql+psycopg2://worldcup:change_me@db:5432/worldcup_ai

# JWT_SECRET signs user login tokens. Use at least 32 random characters in production.
JWT_SECRET=change_me_to_a_long_random_secret

# ADMIN_TOKEN allows temporary admin-only API calls without building an admin UI yet.
ADMIN_TOKEN=change_me_admin_token

# Background data sync scheduler. It syncs fixtures, odds snapshots, and then queues/runs AI jobs.
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_MINUTES=60
SYNC_STARTUP_DELAY_SECONDS=20

# Maximum API-Football rich match-data calls per sync cycle.
# Each match can use events/statistics/lineups calls, so keep this modest on free/low quota plans.
MATCH_DATA_SYNC_LIMIT=12

# Free/public fallback source for basic fixture/event enrichment.
# Public demo key 123 may be rate-limited; use your own TheSportsDB key if available.
THE_SPORTSDB_KEY=123
THE_SPORTSDB_BASE=https://www.thesportsdb.com/api/v1/json
THE_SPORTSDB_SYNC_LIMIT=8
THE_SPORTSDB_EPL_LEAGUE_ID=4328
THE_SPORTSDB_EPL_SEASON=2025-2026
THE_SPORTSDB_WORLDCUP_LEAGUE_ID=
THE_SPORTSDB_WORLDCUP_SEASON=2026

# China Sports Lottery public football feed fallback.
# This uses only public web gateway data, low frequency, and can be disabled if the source blocks NAS requests.
SPORTTERY_ENABLED=true
SPORTTERY_BASE=https://webapi.sporttery.cn/gateway
SPORTTERY_SYNC_LIMIT=20

# Built-in AI analysis switch. Keep false until OPENAI_API_KEY is configured and cost limits are reviewed.
AI_ANALYSIS_ENABLED=false

# Only matches kicking off within this many hours are eligible for AI analysis.
# 168 = next 7 days.
AI_ANALYSIS_LOOKAHEAD_HOURS=168

# Maximum AI jobs executed in one sync cycle. This limits burst spending after each scheduler/manual sync run.
AI_ANALYSIS_MAX_JOBS_PER_SYNC=3

# Maximum successfully completed AI calls per UTC day. This is the main daily token/cost guardrail.
AI_ANALYSIS_DAILY_JOB_LIMIT=20

# Failed AI jobs can retry until this count. After reaching the limit, the job is marked failed.
AI_ANALYSIS_MAX_RETRIES=2

# Prompt version participates in deduplication. Bump to v2/v3 when prompt logic changes and old analyses should be regenerated.
AI_ANALYSIS_PROMPT_VERSION=v1

# Football fixture and odds data providers.
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
THE_ODDS_API_KEY=
THE_ODDS_API_REGIONS=eu
THE_ODDS_API_EPL_SPORT=soccer_epl
THE_ODDS_API_WORLDCUP_SPORT=soccer_fifa_world_cup

# API-Football free plans may not include current seasons such as EPL 2025/26.
# If your key has no access, fixture enrichment will safely skip and fall back to OpenFootball/football-data.org basics.
API_FOOTBALL_EPL_LEAGUE=39
API_FOOTBALL_EPL_SEASON=2025
API_FOOTBALL_WORLDCUP_LEAGUE=1
API_FOOTBALL_WORLDCUP_SEASON=2026

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

RUN_MODE=signal
